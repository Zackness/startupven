// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "mysql"
}

enum UserRole {
  CLIENTE
  VENDEDOR
  EDITOR
  ADMIN
}

enum Gremio {
  ESTUDIANTIL
  OBRERO
  PROFESORES
}

enum Carrera {
  INGENIERIA_MECATRONICA
  INGENIERIA_RURAL
  TSU_ELECTRICA
  TSU_MECANICA
}

model User {
  id               String    @id @default(cuid())
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  email            String    @unique
  emailVerified    Boolean   @default(false)
  name             String
  image            String?
  role             UserRole  @default(CLIENTE)
  gremio           Gremio?
  carrera          Carrera?
  cedula           String?
  expediente       String?   // Solo estudiantes
  primerNombre     String?
  segundoNombre    String?
  primerApellido   String?
  segundoApellido  String?
  accounts         Account[]
  sessions         Session[]
  tickets          Ticket[]
  wallet        WalletTransaction[]
  paymentReports PaymentReport[]
  balance       Decimal   @default(0) @db.Decimal(10, 2)
}

// Lugar de la comida: cantina o comedor
enum LugarComida {
  CANTINA
  COMEDOR
}

// Tipos de ticket (ej. Desayuno, Comida)
model TicketType {
  id               String        @id @default(cuid())
  name             String        // Ej. "Pabellón", "Pasta"
  category         TicketCategory @default(ALMUERZO)
  lugar            LugarComida   @default(COMEDOR) // Cantina o comedor
  price            Decimal       @db.Decimal(10, 2)
  description      String?
  image            String?       // URL de la imagen (BunnyCDN)
  availableForDate DateTime?    @db.Date // Si tiene valor, el ticket solo vale para esta fecha; al pasar se desactiva
  active           Boolean      @default(true)
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
  tickets          Ticket[]
}

enum TicketCategory {
  DESAYUNO
  ALMUERZO
  CENA
}

enum TicketPaymentStatus {
  PENDIENTE
  PAGADO
  REEMBOLSADO
}

// Ticket comprado por un usuario (una comida canjeable)
model Ticket {
  id            String              @id @default(cuid())
  userId        String
  ticketTypeId  String
  mealDate      DateTime            @db.Date
  usedAt        DateTime?
  paymentStatus TicketPaymentStatus @default(PENDIENTE)
  createdAt     DateTime            @default(now())
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  ticketType   TicketType @relation(fields: [ticketTypeId], references: [id], onDelete: Restrict)
  paymentMethod    String              @default("PAGO_MOVIL") // "PAGO_MOVIL" | "STRIPE"
  paymentReference String?
  paymentBank      String?
  @@index([userId])
  @@index([mealDate])
}

model WalletTransaction {
  id          String   @id @default(cuid())
  userId      String
  amount      Decimal  @db.Decimal(10, 2) // Positivo = Crédito, Negativo = Débito
  type        String   // "DEPOSITO" | "COMPRA" | "REEMBOLSO"
  reference   String?  // ID de ticket, referencia bancaria, etc.
  createdAt   DateTime @default(now())

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

enum PaymentReportStatus {
  PENDIENTE
  APROBADO
  RECHAZADO
}

model PaymentReport {
  id          String              @id @default(cuid())
  userId      String
  amount      Decimal             @db.Decimal(10, 2)
  method      String              @default("PAGO_MOVIL") // "PAGO_MOVIL" | "STRIPE"
  bank        String?             // Opcional si es Stripe/PayPal
  reference   String
  status      PaymentReportStatus @default(PENDIENTE)
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  
  user        User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@index([userId])
}

model Account {
  id                   String    @id @default(cuid())
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
  userId               String
  providerId           String
  accountId            String
  accessToken          String?
  refreshToken         String?
  idToken              String?
  accessTokenExpiresAt DateTime?
  refreshTokenExpiresAt DateTime?
  scope                String?
  password             String?
  user                 User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@unique([providerId, accountId])
}

model Session {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  userId    String
  token     String   @unique
  expiresAt DateTime
  ipAddress String?
  userAgent String?
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Verification {
  id         String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  value     String
  expiresAt DateTime
  identifier String
}
