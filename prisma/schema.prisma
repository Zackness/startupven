// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "mysql"
}

enum UserRole {
  CLIENTE
  VENDEDOR
  EDITOR
  ADMIN
}

enum Carrera {
  INGENIERIA_MECATRONICA
  INGENIERIA_RURAL
  TSU_ELECTRICA
  TSU_MECANICA
}

model User {
  id               String    @id @default(cuid())
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  email            String    @unique
  emailVerified    Boolean   @default(false)
  name             String
  image            String?
  role             UserRole  @default(CLIENTE)
  carrera          Carrera?
  cedula           String?
  primerNombre     String?
  segundoNombre    String?
  primerApellido   String?
  segundoApellido  String?
  accounts         Account[]
  sessions         Session[]
  tickets          Ticket[]           @relation("TicketBuyer")
  ticketsSold      Ticket[]           @relation("TicketSeller")
  wallet           WalletTransaction[]
  paymentReports   PaymentReport[]
  withdrawalRequests WithdrawalRequest[]
  balance          Decimal   @default(0) @db.Decimal(10, 2)
  requiresEmailChange    Boolean @default(false) // Obligar a cambiar si es temporal (no institucional)
  requiresPasswordChange Boolean @default(false) // Obligar a cambiar si sigue con contraseña por defecto
  supportTickets   SupportTicket[]
  supportTicketMessages SupportTicketMessage[]
}

// Lugar de la comida: cantina o comedor
enum LugarComida {
  CANTINA
  COMEDOR
}

// Tipos de ticket (ej. Desayuno, Comida)
model TicketType {
  id               String        @id @default(cuid())
  name             String        // Ej. "Pabellón", "Pasta"
  category         TicketCategory @default(ALMUERZO)
  lugar            LugarComida   @default(COMEDOR) // Cantina o comedor
  price            Decimal       @db.Decimal(10, 2)
  description      String?
  image            String?       // URL de la imagen (BunnyCDN)
  availableForDate DateTime?    @db.Date // Si tiene valor, el ticket solo vale para esta fecha; al pasar se desactiva
  maxQuantity      Int?          // Límite de comidas para este plato (null = sin límite)
  active           Boolean      @default(true)
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
  tickets          Ticket[]
}

enum TicketCategory {
  DESAYUNO
  ALMUERZO
  CENA
}

enum TicketPaymentStatus {
  PENDIENTE
  PAGADO
  REEMBOLSADO
}

// Ticket comprado por un usuario o por un invitado (una comida canjeable)
model Ticket {
  id            String              @id @default(cuid())
  userId        String?             // null = venta a invitado
  ticketTypeId  String
  mealDate      DateTime            @db.Date
  usedAt        DateTime?
  paymentStatus TicketPaymentStatus @default(PENDIENTE)
  createdAt     DateTime            @default(now())
  user          User?       @relation("TicketBuyer", fields: [userId], references: [id], onDelete: Cascade)
  ticketType    TicketType @relation(fields: [ticketTypeId], references: [id], onDelete: Restrict)
  paymentMethod    String              @default("PAGO_MOVIL") // "PAGO_MOVIL" | "STRIPE"
  paymentReference String?
  paymentBank      String?
  sellerId         String?
  seller           User?      @relation("TicketSeller", fields: [sellerId], references: [id], onDelete: SetNull)
  guestName        String?             // Nombre del invitado (cuando userId es null)
  guestInstitution String?             // Institución del invitado
  @@index([userId])
  @@index([mealDate])
  @@index([sellerId])
}

model WalletTransaction {
  id          String   @id @default(cuid())
  userId      String
  amount      Decimal  @db.Decimal(10, 2) // Positivo = Crédito, Negativo = Débito
  type        String   // "DEPOSITO" | "COMPRA" | "REEMBOLSO" | "RETIRO"
  reference   String?  // ID de ticket, referencia bancaria, etc.
  createdAt   DateTime @default(now())

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

enum PaymentReportStatus {
  PENDIENTE
  APROBADO
  RECHAZADO
}

model PaymentReport {
  id          String              @id @default(cuid())
  userId      String
  amount      Decimal             @db.Decimal(10, 2)
  method      String              @default("PAGO_MOVIL") // "PAGO_MOVIL" | "STRIPE"
  bank        String?             // Opcional si es Stripe/PayPal
  reference   String
  status      PaymentReportStatus @default(PENDIENTE)
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  
  user        User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@index([userId])
}

enum WithdrawalRequestStatus {
  PENDIENTE
  PROCESADO
  RECHAZADO
}

model WithdrawalRequest {
  id        String                   @id @default(cuid())
  userId    String
  amount    Decimal                  @db.Decimal(10, 2)
  bankName  String?
  bankAccount String?                // Cuenta o datos bancarios para el retiro
  status    WithdrawalRequestStatus @default(PENDIENTE)
  createdAt DateTime                 @default(now())
  updatedAt DateTime                 @updatedAt

  user      User                     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
}

model Account {
  id                   String    @id @default(cuid())
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
  userId               String
  providerId           String
  accountId            String
  accessToken          String?
  refreshToken         String?
  idToken              String?
  accessTokenExpiresAt DateTime?
  refreshTokenExpiresAt DateTime?
  scope                String?
  password             String?
  user                 User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@unique([providerId, accountId])
}

model Session {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  userId    String
  token     String   @unique
  expiresAt DateTime
  ipAddress String?
  userAgent String?
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Verification {
  id         String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  value     String
  expiresAt DateTime
  identifier String
}

/** Tickets de soporte: clientes abren y el equipo (admin/editor) responde. */
enum SupportTicketStatus {
  ABIERTO
  EN_PROCESO
  ESPERANDO_CLIENTE  // En espera de respuesta del cliente
  RESUELTO
  CERRADO
}

model SupportTicket {
  id                String              @id @default(cuid())
  userId            String
  subject           String
  status            SupportTicketStatus @default(ABIERTO)
  allowClientReply  Boolean             @default(false) // Solo si el admin lo permite puede responder el cliente
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt

  user      User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages  SupportTicketMessage[]

  @@index([userId])
  @@index([status])
  @@index([updatedAt])
}

/** Quién escribe el mensaje: queda registrado para saber si es cliente o equipo. */
enum SupportTicketMessageAuthor {
  CLIENTE
  ADMIN
  EDITOR
}

model SupportTicketMessage {
  id              String                    @id @default(cuid())
  supportTicketId String
  userId          String
  authorRole      SupportTicketMessageAuthor? // Registrado al escribir: cliente, admin o editor
  body            String                    @db.Text
  createdAt       DateTime                 @default(now())

  supportTicket   SupportTicket            @relation(fields: [supportTicketId], references: [id], onDelete: Cascade)
  user            User                      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([supportTicketId])
}

/** Proyectos del portafolio público (web). Admin/Editor los crean; se muestran en /proyectos. */
model Project {
  id          String   @id @default(cuid())
  titulo      String
  descripcion String   @db.Text
  tipo        String   // ej. "Página web", "Plataforma", "E-commerce"
  año         String
  imagen      String?  // URL de imagen (opcional)
  url         String?  // URL del sitio en vivo: se renderiza como vista previa si no hay imagen
  orden       Int      @default(0) // Para destacados: menor = más arriba
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([orden])
}
